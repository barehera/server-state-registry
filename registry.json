{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "server-state-registry",
  "homepage": "https://github.com/barehera/server-state-registry",
  "items": [
    {
      "name": "server-state-core",
      "type": "registry:item",
      "title": "Server State Core",
      "description": "Shared project-owned transport, validation, naming, query-option, error, and streaming primitives.",
      "dependencies": [
        "@tanstack/react-query@^5.101.4",
        "axios@^1.18.1",
        "zod@^4.4.3"
      ],
      "files": [
        {
          "path": "registry/server-state-core/src/server-state/api.ts",
          "type": "registry:file",
          "target": "~/src/server-state/api.ts"
        },
        {
          "path": "registry/server-state-core/src/server-state/constants.ts",
          "type": "registry:file",
          "target": "~/src/server-state/constants.ts"
        },
        {
          "path": "registry/server-state-core/src/server-state/names.ts",
          "type": "registry:file",
          "target": "~/src/server-state/names.ts"
        },
        {
          "path": "registry/server-state-core/src/server-state/schemas.ts",
          "type": "registry:file",
          "target": "~/src/server-state/schemas.ts"
        },
        {
          "path": "registry/server-state-core/src/server-state/types.ts",
          "type": "registry:file",
          "target": "~/src/server-state/types.ts"
        },
        {
          "path": "registry/server-state-core/src/server-state/utils.ts",
          "type": "registry:file",
          "target": "~/src/server-state/utils.ts"
        }
      ],
      "docs": "Review the backend error and response envelopes in schemas.ts before using the core. They are project contracts, not universal API shapes."
    },
    {
      "name": "authenticated-query",
      "type": "registry:item",
      "title": "Authenticated Query",
      "description": "Factory for project-auth-aware finite and infinite TanStack Query hooks using enabled composition and skipToken.",
      "dependencies": ["@tanstack/react-query@^5.101.4"],
      "files": [
        {
          "path": "registry/authenticated-query/src/server-state/create-authenticated-query-hooks.ts",
          "type": "registry:file",
          "target": "~/src/server-state/create-authenticated-query-hooks.ts"
        }
      ],
      "docs": "Create one project auth integration file that passes the real auth hook to createAuthenticatedQueryHooks. Feature hooks then import the configured useAuthenticatedQuery."
    },
